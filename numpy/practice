# 13. A data class pattern with methods
class Student:
    def __init__(self, name, grades):
        self.name = name
        self.grades = np.array(grades)

    def average(self):
        return self.grades.mean()

student = Student('Amy', [80, 90, 100])
print(student.average())  # stores grades and computes average

# 14. More complex example: batch data class with numpy stats
class Batch:
    def __init__(self, values):
        self.values = np.array(values, dtype=float)

    def mean(self):
        return self.values.mean()

    def variance(self):
        return self.values.var()

    def add_value(self, value):
        self.values = np.append(self.values, value)

batch = Batch([1, 2, 4, 8])
batch.add_value(16)
print(batch.mean(), batch.variance())  # class holds array and updates it
